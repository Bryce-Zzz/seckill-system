#include "handler/seckill_handler.h"
#include "handler/sse_handler.h"
#include "service/redis_service.h"
#include "service/rate_limiter.h"
#include "service/mysql_service.h"
#include "service/order_processor.h"
#include "common/logger.h"
#include "common/config.h"
#include "common/metrics.h"
#include <hv/json.hpp>
#include <sstream>
#include <iomanip>
#include <random>
#include <chrono>


using json = nlohmann::json;

// 辅助函数：手动解析 URL 编码的 body
static inline std::string parse_url_encoded_body(const std::string& body, const char* key, const char* def = "") {
    if (body.empty()) return def;
    size_t pos = 0;
    while (pos < body.size()) {
        // 查找 key
        size_t eq = body.find('=', pos);
        size_t amp = body.find('&', pos);
        if (eq == std::string::npos) break;
        
        std::string k = body.substr(pos, eq - pos);
        size_t val_start = eq + 1;
        size_t val_end = (amp == std::string::npos) ? body.size() : amp;
        std::string v = body.substr(val_start, val_end - val_start);
        
        if (k == key) return v;
        pos = (amp == std::string::npos) ? body.size() : amp + 1;
    }
    return def;
}

// 从 query 或 body 获取参数
static inline std::string get_param(const HttpRequest* req, const char* key, const char* def = "") {
    // 先查 URL query params
    auto it = req->query_params.find(key);
    if (it != req->query_params.end()) return it->second;
    
    // 再手动解析 POST body
    return parse_url_encoded_body(req->body, key, def);
}

// 秒杀 Lua 脚本（防止超卖）
static const char* SECKILL_LUA = R"(
local stock_key = KEYS[1]
local order_set_key = KEYS[2]
local user_id = ARGV[1]
local quantity = tonumber(ARGV[2])

-- 检查用户是否已购买
local bought = redis.call('SISMEMBER', order_set_key, user_id)
if bought == 1 then
    return -2
end

-- 检查库存
local stock = tonumber(redis.call('GET', stock_key) or 0)
if stock < quantity then
    return -1
end

-- 原子扣减库存
redis.call('DECRBY', stock_key, quantity)
redis.call('SADD', order_set_key, user_id)

return stock - quantity
)";

// 秒杀处理
static int handle_seckill(HttpRequest* req, HttpResponse* resp) {
    try {
    auto t0 = std::chrono::steady_clock::now();
    Metrics::instance().inc_requests_total();

    auto& cfg = Config::instance();
    
    // 获取客户端 IP 用于限流
    std::string client_ip = req->client_addr.ip;
    
    // 检查限流
    if (!RateLimiter::instance().allow(client_ip)) {
        Metrics::instance().inc_seckill_fail_ratelimit();
        json json_resp;
        json_resp["code"] = 429;
        json_resp["msg"] = "Too Many Requests";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        resp->status_code = HTTP_STATUS_TOO_MANY_REQUESTS;
        return HTTP_STATUS_TOO_MANY_REQUESTS;
    }
    
    // 解析参数 - 支持 URL query params 和 POST body
    std::string user_id = get_param(req, "user_id");
    std::string product_id = get_param(req, "product_id");
    std::string qty_str = get_param(req, "quantity", "1");
    int quantity = std::atoi(qty_str.c_str());
    
    json json_resp;
    if (user_id.empty() || product_id.empty()) {
        json_resp["code"] = 400;
        json_resp["msg"] = "Missing parameters";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        resp->status_code = HTTP_STATUS_BAD_REQUEST;
        return HTTP_STATUS_BAD_REQUEST;
    }
    
    // 检查冷却时间（取消订单后60秒内不能再次购买同一商品）
    auto& redis = RedisService::instance();
    std::string cooldown_key = "seckill:cooldown:" + user_id + ":" + product_id;
    if (redis.exists(cooldown_key)) {
        json_resp["code"] = 429;
        json_resp["msg"] = "Cooldown, please wait";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        resp->status_code = HTTP_STATUS_TOO_MANY_REQUESTS;
        return HTTP_STATUS_TOO_MANY_REQUESTS;
    }
    
    // 生成订单 ID
    auto now = std::chrono::duration_cast<std::chrono::milliseconds>(
        std::chrono::system_clock::now().time_since_epoch()).count();
    std::random_device rd;
    std::mt19937 gen(rd());
    std::ostringstream oss;
    oss << "ORD" << now << std::setfill('0') << std::setw(6) << gen() % 1000000;
    std::string order_id = oss.str();

    // 构建 Redis key
    std::string stock_key = cfg.seckill.stock_prefix + product_id;
    std::string order_set_key = cfg.seckill.order_set_prefix + product_id;

    // 执行 Lua 脚本（原子操作）
    long long result = redis.eval(SECKILL_LUA, {stock_key, order_set_key}, {user_id, std::to_string(quantity)});

    if (result >= 0) {
        // 秒杀成功
        Metrics::instance().inc_seckill_success();
        Order order;
        order.order_id = order_id;
        order.user_id = user_id;
        order.product_id = product_id;
        order.quantity = quantity;
        order.status = 0;
        order.created_at = now;

        // 写入 Redis Stream 异步处理
        redis.xadd(cfg.seckill.order_stream_key, "order_data", 
            order_id + "|" + user_id + "|" + product_id + "|" + std::to_string(quantity) + "|0|" + std::to_string(now));

        // 异步写入 MySQL
        OrderProcessor::instance().push_order(order);

        json_resp["code"] = 200;
        json_resp["msg"] = "Seckill success";
        json_resp["order_id"] = order_id;
        json_resp["remaining_stock"] = result;

        Logger::instance().info("Seckill success: order_id=" + order_id + 
                                ", user_id=" + user_id + ", product_id=" + product_id);
        
        // 广播秒杀成功事件
        json event_data = {
            {"order_id", order_id},
            {"user_id", user_id},
            {"product_id", product_id},
            {"quantity", quantity},
            {"remaining_stock", result}
        };
        SSEHandler::instance().broadcast("order_created", event_data.dump());
        resp->status_code = (http_status)200;
    } else if (result == -1) {
        Metrics::instance().inc_seckill_fail_sold();
        json_resp["code"] = 409;
        json_resp["msg"] = "Sold out";
        resp->status_code = HTTP_STATUS_CONFLICT;
        Logger::instance().debug("Seckill failed: sold out, user_id=" + user_id + 
                                ", product_id=" + product_id);
    } else if (result == -2) {
        Metrics::instance().inc_seckill_fail_dup();
        json_resp["code"] = 409;
        json_resp["msg"] = "Already purchased";
        resp->status_code = HTTP_STATUS_CONFLICT;
        Logger::instance().debug("Seckill failed: already purchased, user_id=" + user_id + 
                                ", product_id=" + product_id);
    } else {
        json_resp["code"] = 500;
        json_resp["msg"] = "Internal error";
        resp->status_code = HTTP_STATUS_INTERNAL_SERVER_ERROR;
    }

    resp->body = json_resp.dump();
    resp->SetContentType("application/json");

    // 记录延迟
    auto t1 = std::chrono::steady_clock::now();
    long long us = std::chrono::duration_cast<std::chrono::microseconds>(t1 - t0).count();
    Metrics::instance().observe_latency_us(us);

    return (int)resp->status_code;
    } catch (const std::exception& e) {
        Logger::instance().error("Seckill handler exception: " + std::string(e.what()));
        json json_resp;
        json_resp["code"] = 500;
        json_resp["msg"] = "Internal error";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        resp->status_code = HTTP_STATUS_INTERNAL_SERVER_ERROR;
        return HTTP_STATUS_INTERNAL_SERVER_ERROR;
    } catch (...) {
        Logger::instance().error("Seckill handler unknown exception");
        json json_resp;
        json_resp["code"] = 500;
        json_resp["msg"] = "Internal error";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        resp->status_code = HTTP_STATUS_INTERNAL_SERVER_ERROR;
        return HTTP_STATUS_INTERNAL_SERVER_ERROR;
    }
}

// 获取商品列表
static int handle_list_products(HttpRequest* req, HttpResponse* resp) {
    try {
    (void)req;
    
    auto products = MySQLService::instance().get_all_products();

    json json_resp;
    json_resp["code"] = 200;
    json_resp["products"] = json::array();

    for (const auto& p : products) {
        // 实时获取 Redis 中的秒杀库存
        std::string stock_key = Config::instance().seckill.stock_prefix + p.id;
        std::string redis_stock = RedisService::instance().get(stock_key);
        
        // 判断是否在秒杀中：Redis 中有库存且 > 0
        bool seckill_active = !redis_stock.empty() && std::stoi(redis_stock) > 0;
        int seckill_stock = redis_stock.empty() ? 0 : std::stoi(redis_stock);
        
        json obj = {
            {"id", p.id},
            {"name", p.name},
            {"stock", p.stock},           // MySQL 原始库存
            {"seckill_stock", seckill_stock},  // 秒杀库存（Redis）
            {"seckill_active", seckill_active}, // 是否在秒杀中
            {"price", p.price}
        };
        json_resp["products"].push_back(obj);
    }

    resp->body = json_resp.dump();
    resp->SetContentType("application/json");
    return 200;
    } catch (const std::exception& e) {
        Logger::instance().error("List products exception: " + std::string(e.what()));
        json json_resp;
        json_resp["code"] = 500;
        json_resp["msg"] = "Internal error";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        return 500;
    } catch (...) {
        Logger::instance().error("List products unknown exception");
        json json_resp;
        json_resp["code"] = 500;
        json_resp["msg"] = "Internal error";
        resp->body = json_resp.dump();
        resp->SetContentType("application/json");
        return 500;
    }
}

// 注册路由
void register_seckill_routes(hv::HttpService* service) {
    service->POST("/api/seckill/buy", handle_seckill);  // 秒杀购买（POST）
    service->GET("/api/products",     handle_list_products);
    service->GET("/api/seckill/products", handle_list_products);
}
