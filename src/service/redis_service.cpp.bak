long long RedisService::eval(const std::string& script, const std::vector<std::string>& keys,
                              const std::vector<std::string>& args) {
    if (!context_) return 0;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    
    std::vector<const char*> argv;
    std::vector<size_t> argvlen;
    
    argv.push_back("EVAL");
    argvlen.push_back(4);
    
    argv.push_back(script.c_str());
    argvlen.push_back(script.size());
    
    char numkeys[16];
    snprintf(numkeys, sizeof(numkeys), "%zu", keys.size());
    argv.push_back(numkeys);
    argvlen.push_back(strlen(numkeys));
    
    for (const auto& k : keys) {
        argv.push_back(k.c_str());
        argvlen.push_back(k.size());
    }
    
    for (const auto& a : args) {
        argv.push_back(a.c_str());
        argvlen.push_back(a.size());
    }
    
    auto* reply = (redisReply*)redisCommandArgv(context_, argv.size(), argv.data(), argvlen.data());
    if (!reply) return 0;
    
    long long result = 0;
    if (reply->type == REDIS_REPLY_INTEGER) {
        result = reply->integer;
    }
    freeReplyObject(reply);
    return result;
}

std::string RedisService::eval_string(const std::string& script, const std::vector<std::string>& keys,
                                        const std::vector<std::string>& args) {
    if (!context_) return "";
    std::lock_guard<std::mutex> lock(redis_mutex_);
    
    std::vector<const char*> argv;
    std::vector<size_t> argvlen;
    
    argv.push_back("EVAL");
    argvlen.push_back(4);
    
    argv.push_back(script.c_str());
    argvlen.push_back(script.size());
    
    char numkeys[16];
    snprintf(numkeys, sizeof(numkeys), "%zu", keys.size());
    argv.push_back(numkeys);
    argvlen.push_back(strlen(numkeys));
    
    for (const auto& k : keys) {
        argv.push_back(k.c_str());
        argvlen.push_back(k.size());
    }
    
    for (const auto& a : args) {
        argv.push_back(a.c_str());
        argvlen.push_back(a.size());
    }
    
    auto* reply = (redisReply*)redisCommandArgv(context_, argv.size(), argv.data(), argvlen.data());
    if (!reply) return "";
    
    std::string result;
    if (reply->type == REDIS_REPLY_STRING) {
        result = std::string(reply->str, reply->len);
    }
    freeReplyObject(reply);
    return result;
}

bool RedisService::xadd(const std::string& key, const std::string& field, const std::string& value) {
    if (!context_) return false;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    
    auto* reply = (redisReply*)redisCommand(context_, 
        "XADD %s * %s %s", key.c_str(), field.c_str(), value.c_str());
    if (!reply) return false;
    
    bool ok = reply->type == REDIS_REPLY_STRING;
    freeReplyObject(reply);
    return ok;
}

std::vector<std::string> RedisService::xrange(const std::string& key, const std::string& start, 
                                               const std::string& end, int count) {
    std::vector<std::string> results;
    if (!context_) return results;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    
    auto* reply = (redisReply*)redisCommand(context_,
        "XRANGE %s %s %s COUNT %d", key.c_str(), start.c_str(), end.c_str(), count);
    if (!reply) return results;
    
    if (reply->type == REDIS_REPLY_ARRAY) {
        for (size_t i = 0; i < reply->elements; ++i) {
            auto* item = reply->element[i];
            if (item->type == REDIS_REPLY_ARRAY && item->elements >= 2) {
                results.push_back(std::string(item->element[1]->str, item->element[1]->len));
            }
        }
    }
    freeReplyObject(reply);
    return results;
}

bool RedisService::xdel(const std::string& key, const std::string& id) {
    if (!context_) return false;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    auto* reply = (redisReply*)redisCommand(context_, "XDEL %s %s", key.c_str(), id.c_str());
    if (!reply) return false;
    
    bool ok = reply->type == REDIS_REPLY_INTEGER && reply->integer > 0;
    freeReplyObject(reply);
    return ok;
}

void RedisService::close() {
    if (context_) {
        redisFree(context_);
        context_ = nullptr;
    }
}
