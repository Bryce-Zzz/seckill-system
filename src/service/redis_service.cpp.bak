#include "service/redis_service.h"
#include "common/logger.h"
#include <cstring>
#include <sstream>

bool RedisService::init(const std::string& host, int port, const std::string& password, int db, int pool_size) {
    redisContext* ctx = redisConnect(host.c_str(), port);
    if (!ctx || ctx->err) {
        if (ctx) {
            std::string err_msg = "Redis connection error: " + std::string(ctx->errstr);
            Logger::instance().error(err_msg);
            redisFree(ctx);
        } else {
            Logger::instance().error("Redis connection failed: can't allocate redis context");
        }
        return false;
    }

    if (!password.empty()) {
        auto* reply = (redisReply*)redisCommand(ctx, "AUTH %s", password.c_str());
        if (reply && reply->type == REDIS_REPLY_ERROR) {
            std::string err_msg = "Redis auth error: " + std::string(reply->str ? reply->str : "unknown");
            Logger::instance().error(err_msg);
            freeReplyObject(reply);
            redisFree(ctx);
            return false;
        }
        if (reply) freeReplyObject(reply);
    }

    if (db > 0) {
        auto* reply = (redisReply*)redisCommand(ctx, "SELECT %d", db);
        if (reply && reply->type == REDIS_REPLY_ERROR) {
            std::string err_msg = "Redis select db error: " + std::string(reply->str ? reply->str : "unknown");
            Logger::instance().error(err_msg);
            freeReplyObject(reply);
            redisFree(ctx);
            return false;
        }
        if (reply) freeReplyObject(reply);
    }

    context_ = ctx;
    Logger::instance().info("Redis connected successfully");
    return true;
}

std::string RedisService::get(const std::string& key) {
    if (!context_) return "";
    std::lock_guard<std::mutex> lock(redis_mutex_);
    auto* reply = (redisReply*)redisCommand(context_, "GET %s", key.c_str());
    if (!reply) return "";
    
    std::string result;
    if (reply->type == REDIS_REPLY_STRING) {
        result = std::string(reply->str, reply->len);
    }
    freeReplyObject(reply);
    return result;
}

bool RedisService::set(const std::string& key, const std::string& value) {
    if (!context_) return false;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    auto* reply = (redisReply*)redisCommand(context_, "SET %s %s", key.c_str(), value.c_str());
    if (!reply) return false;
    
    bool ok = reply->type != REDIS_REPLY_ERROR;
    freeReplyObject(reply);
    return ok;
}

bool RedisService::setex(const std::string& key, int expire_seconds, const std::string& value) {
    if (!context_) return false;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    auto* reply = (redisReply*)redisCommand(context_, "SETEX %s %d %s", key.c_str(), expire_seconds, value.c_str());
    if (!reply) return false;
    
    bool ok = reply->type != REDIS_REPLY_ERROR;
    freeReplyObject(reply);
    return ok;
}

long long RedisService::incr(const std::string& key) {
    if (!context_) return 0;
    std::lock_guard<std::mutex> lock(redis_mutex_);
    auto* reply = (redisReply*)redisCommand(context_, "INCR %s", key.c_str());
    if (!reply) return 0;
    
    long long result = reply->type == REDIS_REPLY_INTEGER ? reply->integer : 0;
    freeReplyObject(reply);
    return result;
}

