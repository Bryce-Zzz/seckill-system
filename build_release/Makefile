src/service/timeout_checker.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/seckill-server.dir/build.make CMakeFiles/seckill-server.dir/src/service/timeout_checker.cpp.s
.PHONY : src/service/timeout_checker.cpp.s

